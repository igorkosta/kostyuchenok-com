{
  "version": 2,
  "builds": [
    {
      "src": "api/telegram.js",
      "use": "@vercel/node"
    },
    {
      "src": "middleware.js",
      "use": "@vercel/edge"
    }
  ],
  "routes": [
    {
      "src": "/api/telegram/(.*)",
      "dest": "/api/telegram.js"
    },
    {
      "src": "/api/telegram",
      "dest": "/api/telegram.js"
    }
  ]
}
